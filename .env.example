# Starknet
NEXT_PUBLIC_STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
NEXT_PUBLIC_STARKNET_RPC_FALLBACK_1=
NEXT_PUBLIC_STARKNET_RPC_FALLBACK_2=
NEXT_PUBLIC_STARKNET_RPC_FALLBACK_3=
NEXT_PUBLIC_CHAIN_ID=SN_SEPOLIA

# Season (set to your launch date; default is 2026-05-03T00:00:00Z)
NEXT_PUBLIC_SEASON_START=2026-05-03T00:00:00Z

# Mezcal — fast indexed read layer (falls back to RPC if not set)
# Get a key at https://preview.188.245.249.37.nip.io
NEXT_PUBLIC_MEZCAL_API_URL=https://preview.188.245.249.37.nip.io
NEXT_PUBLIC_MEZCAL_API_KEY=mzk_live_your_key_here

# Deployed contract addresses (fill after deployment)
NEXT_PUBLIC_VIBECARD_CONTRACT_ADDRESS=0x0
NEXT_PUBLIC_LEADERBOARD_CONTRACT_ADDRESS=0x0
NEXT_PUBLIC_SEASON_CLOCK_CONTRACT_ADDRESS=0x0

# Oracle
ORACLE_ADDRESS=0x0             # server-side only
ORACLE_PRIVATE_KEY=            # server-side only, never expose client-side
ORACLE_SECRET=                 # for /api/oracle/resolve auth

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# APIs
NEXT_PUBLIC_VOYAGER_API_KEY=your_voyager_api_key

# IPFS (web3.storage for encrypted salt storage)
WEB3_STORAGE_TOKEN=your_web3storage_token

# Telegram bot notifications
TELEGRAM_BOT_TOKEN=          # from @BotFather
TELEGRAM_CHANNEL_ID=@YourChannelUsername
NEXT_PUBLIC_SITE_URL=https://your-deployment-url.vercel.app
