# Starknet
NEXT_PUBLIC_STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
NEXT_PUBLIC_CHAIN_ID=SN_SEPOLIA

# Deployed contract addresses (fill after deployment)
NEXT_PUBLIC_VIBECARD_CONTRACT_ADDRESS=0x0
NEXT_PUBLIC_LEADERBOARD_CONTRACT_ADDRESS=0x0
NEXT_PUBLIC_SEASON_CLOCK_CONTRACT_ADDRESS=0x0

# Oracle
NEXT_PUBLIC_ORACLE_ADDRESS=0x0
ORACLE_PRIVATE_KEY=             # server-side only, never expose client-side

# APIs
NEXT_PUBLIC_VOYAGER_API_KEY=your_voyager_api_key

# IPFS (web3.storage for encrypted salt storage)
WEB3_STORAGE_TOKEN=your_web3storage_token
